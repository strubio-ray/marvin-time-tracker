# Marvin API
MARVIN_API_TOKEN=your-marvin-api-token-here

# Apple Push Notification Service
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
APNS_BUNDLE_ID=com.strubio.MarvinTimeTracker

# Server
LISTEN_ADDR=:8080
STATE_FILE_PATH=./state.json

# Polling intervals
POLL_INTERVAL_ACTIVE=30s
POLL_INTERVAL_IDLE=5m

# iOS Code Signing
DEVELOPMENT_TEAM=XXXXXXXXXX

# App Store Connect API (for TestFlight uploads)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_P8_PATH=~/.private_keys/AuthKey.p8
# ASC_KEY_CONTENT=  # Alternative: paste raw p8 contents (for CI)
