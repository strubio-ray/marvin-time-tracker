# Device (run `xcodebuild -scheme MarvinTimeTracker -showdestinations` to find your device ID)
DEVICE_ID=YOUR_DEVICE_ID_HERE

# iOS Code Signing
DEVELOPMENT_TEAM=XXXXXXXXXX
MATCH_GIT_URL=https://github.com/YOUR_USERNAME/vibetunnel-certificates.git

# App Store Connect API (for match, TestFlight uploads)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_P8_PATH=~/.private_keys/AuthKey.p8
