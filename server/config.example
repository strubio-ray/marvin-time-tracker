# Marvin Relay Configuration
# Copy this file and fill in your values.
# Environment variables override values set here.
#
# Dev:      cp server/config.example server/config && make run
# Homebrew: edit /opt/homebrew/etc/marvin-relay/config

# Marvin API (required)
MARVIN_API_TOKEN = your-marvin-api-token-here
# Full Access Token (required, needed for stopping tracking from the iOS app)
# Get from https://app.amazingmarvin.com/pre?api
MARVIN_FULL_ACCESS_TOKEN = your-full-access-token-here

# Apple Push Notification Service
APNS_KEY_ID = XXXXXXXXXX
APNS_TEAM_ID = XXXXXXXXXX
APNS_KEY_P8_PATH = ~/.private_keys/AuthKey.p8
APNS_BUNDLE_ID = com.strubio.MarvinTimeTracker

# Server
LISTEN_ADDR = :8080
# Dev: ./state.json | Homebrew: /opt/homebrew/var/marvin-relay/state.json
STATE_FILE_PATH = ./state.json

# API key for iOS app authentication (Bearer token)
# Generate with: openssl rand -hex 32
# API_KEY = your-api-key-here

# Public URL for userscript @updateURL/@downloadURL rewriting
# (e.g., https://relay.example.com). If empty, auto-update URLs are left as placeholders.
# EXTERNAL_URL = https://relay.example.com
